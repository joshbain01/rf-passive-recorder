[Unit]
Description=rf-passive-recorder daemon
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/rf-passive-recorder
Environment=RFPR_CONFIG=/etc/rf-passive-recorder/settings.yaml
ExecStart=/opt/rf-passive-recorder/.venv/bin/rfpr run --config ${RFPR_CONFIG}
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
